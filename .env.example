# Supabase Configuration
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI Provider Configuration
# Choose ONE provider and fill in the corresponding key.
# The app will use the first available provider in order: Gemini -> OpenAI -> Anthropic -> Proxy -> Local Simulation.

# Google Gemini (PRIMARY - Recommended)
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# OpenAI
VITE_OPENAI_API_KEY=
VITE_OPENAI_API_URL=https://api.openai.com/v1/chat/completions
VITE_OPENAI_MODEL=gpt-4o-mini

# Anthropic
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
VITE_ANTHROPIC_MODEL=claude-3-haiku-20240307

# Local / Proxy Override (optional)
# If set, ALL requests route through this proxy endpoint instead of direct provider calls.
# Useful for Vercel/Supabase Edge Functions or custom backend.
VITE_AI_PROXY_URL=
